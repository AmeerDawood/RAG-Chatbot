# Copy this file to .env and fill in real values. Never commit the real .env.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Asia/Karachi

# CORS / CSRF — comma-separated list of origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Redis (used to cache chatbot answers)
REDIS_URL=redis://127.0.0.1:6379/1

# Embeddings — run locally via a free HuggingFace model, no API key needed.
# First run downloads the model weights (a few hundred MB) to
# ~/.cache/huggingface and caches them there for all future runs.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Answer generation — Groq (free tier available at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Uploads
MAX_UPLOAD_SIZE_MB=20

LOG_LEVEL=INFO
