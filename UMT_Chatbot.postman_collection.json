		{
			"name": "Documents (Admin only)",
			"item": [
				{
					"name": "Upload Document",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const data = pm.response.json();",
									"    if (data.uploaded_id) {",
									"        pm.collectionVariables.set('uploaded_id', data.uploaded_id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{access_token}}", "type": "string"}]
						},
						"body": {
							"mode": "formdata",
							"formdata": [
								{"key": "title", "value": "Admission Policy 2026", "type": "text"},
								{"key": "file", "type": "file", "src": []}
							]
						},
						"url": {
							"raw": "{{base_url}}/upload/",
							"host": ["{{base_url}}"],
							"path": ["upload", ""]
