		"name": "UMT Chatbot (Groq edition)",
		"description": "Django + DRF RAG chatbot API for the University of Management and Technology. Covers auth (JWT), chat query/history, and admin-only document management endpoints.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Get CSRF Cookie",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/api/set-csrf/",
							"host": ["{{base_url}}"],
							"path": ["auth", "api", "set-csrf", ""]
						}
					},
					"response": []
				},
				{
					"name": "Signup",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"jdoe\",\n    \"email\": \"jdoe@example.com\",\n    \"password\": \"StrongPass123\",\n    \"confirm_password\": \"StrongPass123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/signup/",
							"host": ["{{base_url}}"],
							"path": ["auth", "signup", ""]
						}
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const data = pm.response.json();",
									"    if (data.tokens) {",
									"        pm.collectionVariables.set('access_token', data.tokens.access);",
									"        pm.collectionVariables.set('refresh_token', data.tokens.refresh);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"identifier\": \"jdoe@example.com\",\n    \"password\": \"StrongPass123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login/",
							"host": ["{{base_url}}"],
							"path": ["auth", "login", ""]
						}
					},
					"response": []
				},
				{
					"name": "Get Logged-in User (Me)",
					"request": {
						"method": "GET",
						"header": [],
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{access_token}}", "type": "string"}]
						},
						"url": {
							"raw": "{{base_url}}/auth/me/",
							"host": ["{{base_url}}"],
							"path": ["auth", "me", ""]
						}
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [],
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{access_token}}", "type": "string"}]
						},
						"url": {
							"raw": "{{base_url}}/auth/logout/",
							"host": ["{{base_url}}"],
							"path": ["auth", "logout", ""]
						}
					},
					"response": []
				},
				{
					"name": "Token Obtain Pair",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"jdoe\",\n    \"password\": \"StrongPass123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/token/",
							"host": ["{{base_url}}"],
							"path": ["auth", "token", ""]
						}
					},
					"response": []
				},
				{
					"name": "Token Refresh",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const data = pm.response.json();",
									"    if (data.access) {",
									"        pm.collectionVariables.set('access_token', data.access);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/token/refresh/",
							"host": ["{{base_url}}"],
							"path": ["auth", "token", "refresh", ""]
						}
					},
					"response": []
				}
			]
		},
